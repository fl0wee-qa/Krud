generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  QA
  DEVELOPER
  VIEWER
}

enum Methodology {
  SCRUM
  KANBAN
}

enum TestCaseStatus {
  DRAFT
  READY
  DEPRECATED
}

enum TestCaseType {
  FUNCTIONAL
  REGRESSION
  SMOKE
}

enum TestRunResultStatus {
  PASS
  FAIL
  BLOCKED
}

enum BugSeverity {
  S1
  S2
  S3
  S4
}

enum BugPriority {
  P1
  P2
  P3
  P4
}

enum BugStatus {
  OPEN
  IN_PROGRESS
  READY_FOR_QA
  CLOSED
}

enum SprintStatus {
  PLANNED
  ACTIVE
  COMPLETED
}

enum IntegrationType {
  SLACK
  GITHUB
  GITLAB
}

enum IntegrationMode {
  MOCK
  WEBHOOK
  LINKS
  GITHUB_API
}

enum OutboundEventStatus {
  QUEUED
  SENT
  FAILED
}

model User {
  id            String          @id @default(uuid())
  email         String          @unique
  passwordHash  String
  name          String
  role          UserRole        @default(QA)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  projectMember ProjectMember[]
  assignedRuns  TestRun[]       @relation("AssignedTestRuns")
  reportedBugs  Bug[]           @relation("ReportedBugs")
  assignedBugs  Bug[]           @relation("AssignedBugs")
  createdCases  TestCase[]
  savedFilters  SavedFilter[]
  auditLogs     AuditLog[]
}

model Project {
  id                      String         @id @default(uuid())
  name                    String
  key                     String         @unique
  methodology             Methodology    @default(SCRUM)
  modules                 Json?
  workflowConfig          Json?
  customFields            Json?
  tags                    String[]
  sprintDurationDays      Int            @default(14)
  gitIntegrationSettings  Json?
  slackIntegrationSetting Json?
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt
  members                 ProjectMember[]
  testSuites              TestSuite[]
  testCases               TestCase[]
  testRuns                TestRun[]
  bugs                    Bug[]
  sprints                 Sprint[]
  boardColumns            BoardColumn[]
  specifications          Specification[]
  auditLogs               AuditLog[]
  savedFilters            SavedFilter[]
  integrations            Integration[]
  outboundEvents          OutboundEvent[]
}

model ProjectMember {
  id        String   @id @default(uuid())
  projectId String
  userId    String
  role      UserRole
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
}

model TestSuite {
  id        String      @id @default(uuid())
  projectId String
  name      String
  parentId  String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  project   Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent    TestSuite?  @relation("TestSuiteTree", fields: [parentId], references: [id], onDelete: SetNull)
  children  TestSuite[] @relation("TestSuiteTree")
  testCases TestCase[]
}

model TestCase {
  id            String         @id @default(uuid())
  projectId     String
  suiteId       String?
  title         String
  description   String?
  preconditions String?
  steps         Json
  expected      String?
  priority      BugPriority
  status        TestCaseStatus @default(DRAFT)
  type          TestCaseType
  tags          String[]
  linkedSpecId  String?
  createdById   String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  project       Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  suite         TestSuite?     @relation(fields: [suiteId], references: [id], onDelete: SetNull)
  linkedSpec    Specification? @relation(fields: [linkedSpecId], references: [id], onDelete: SetNull)
  createdBy     User           @relation(fields: [createdById], references: [id], onDelete: Cascade)
  runResults    TestRunResult[]
  linkedBugs    Bug[]
}

model TestRun {
  id            String          @id @default(uuid())
  projectId     String
  name          String
  assignedQaId  String?
  executionDate DateTime
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  project       Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignedQa    User?           @relation("AssignedTestRuns", fields: [assignedQaId], references: [id], onDelete: SetNull)
  results       TestRunResult[]
}

model TestRunResult {
  id         String              @id @default(uuid())
  testRunId  String
  testCaseId String
  result     TestRunResultStatus
  comment    String?
  linkedBugId String?
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  testRun    TestRun             @relation(fields: [testRunId], references: [id], onDelete: Cascade)
  testCase   TestCase            @relation(fields: [testCaseId], references: [id], onDelete: Cascade)
  linkedBug  Bug?                @relation(fields: [linkedBugId], references: [id], onDelete: SetNull)

  @@unique([testRunId, testCaseId])
}

model Bug {
  id                 String       @id @default(uuid())
  projectId          String
  title              String
  description        String?
  stepsToReproduce   String?
  expected           String?
  actual             String?
  severity           BugSeverity
  priority           BugPriority
  status             BugStatus    @default(OPEN)
  linkedTestCaseId   String?
  linkedGitCommit    String?
  sprintId           String?
  columnId           String?
  assigneeId         String?
  reporterId         String
  tags               String[]
  attachments        Json?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  project            Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  linkedTestCase     TestCase?    @relation(fields: [linkedTestCaseId], references: [id], onDelete: SetNull)
  sprint             Sprint?      @relation(fields: [sprintId], references: [id], onDelete: SetNull)
  column             BoardColumn? @relation(fields: [columnId], references: [id], onDelete: SetNull)
  assignee           User?        @relation("AssignedBugs", fields: [assigneeId], references: [id], onDelete: SetNull)
  reporter           User         @relation("ReportedBugs", fields: [reporterId], references: [id], onDelete: Cascade)
  runResults         TestRunResult[]
}

model Sprint {
  id          String       @id @default(uuid())
  projectId   String
  name        String
  goal        String?
  startDate   DateTime
  endDate     DateTime
  status      SprintStatus @default(PLANNED)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  bugs        Bug[]
}

model BoardColumn {
  id        String   @id @default(uuid())
  projectId String
  name      String
  position  Int
  wipLimit  Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  bugs      Bug[]
}

model Specification {
  id          String        @id @default(uuid())
  projectId   String
  title       String
  markdown    String
  attachments Json?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  project     Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  versions    SpecVersion[]
  testCases   TestCase[]
}

model SpecVersion {
  id              String        @id @default(uuid())
  specificationId String
  version         Int
  markdown        String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  specification   Specification @relation(fields: [specificationId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id         String   @id @default(uuid())
  projectId  String?
  userId     String?
  entityType String
  entityId   String
  action     String
  payload    Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  project    Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model SavedFilter {
  id        String   @id @default(uuid())
  projectId String
  userId    String
  name      String
  query     String
  preset    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Integration {
  id        String          @id @default(uuid())
  projectId String
  type      IntegrationType
  mode      IntegrationMode
  enabled   Boolean         @default(true)
  settings  Json?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  project   Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model OutboundEvent {
  id         String              @id @default(uuid())
  projectId  String?
  type       String
  payload    Json
  status     OutboundEventStatus @default(QUEUED)
  error      String?
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  project    Project?            @relation(fields: [projectId], references: [id], onDelete: SetNull)
}
